# Makefile for Q2 Forest Fire
#next lines generated by AI

CXX = g++
# using -O3 for maximum execution speed, -Wall for warnings, and C++17 standard
CXXFLAGS = -O3 -Wall -std=c++17 -march=native

# name of the executable (must match what you call in forest_fire.sh)
TARGET = forest_fire

# source file
SRC = forest_fire.cpp

all: $(TARGET)

$(TARGET): $(SRC)
	$(CXX) $(CXXFLAGS) -o $(TARGET) $(SRC)

clean:
	rm -f $(TARGET)